{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "jsonl",
      "camelcase": "JSONL",
      "title": "JSON Lines",
      "scope": "source.jsonl",
      "file-types": [
        "ndjson",
        "jsonlines",
        "jsonl"
      ],
      "injection-regex": "^jsonl$",
      "class-name": "TreeSitterJsonl"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for JSONL",
    "authors": [
      {
        "name": "Kristofers Solo",
        "email": "dev@kristofers.xyz"
      }
    ],
    "links": {
      "repository": "https://codeberg.org/kristoferssolo/tree-sitter-jsonl"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}

